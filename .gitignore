# Dependencies
node_modules/

# Build outputs
dist/
build/

# Runtime bundle (di-generate oleh build-backend-bundle.js, tidak perlu commit)
backend-runtime/
backend-runtime.zip

# Prisma — generated client (di-generate ulang via prisma generate)
node_modules/.prisma/
prisma/generated/

# Environment variables — JANGAN commit file .env asli
.env
.env.local
.env.development
.env.production
# Catch-all for any other .env variants
.env.*
# ✅ Tapi .env.example HARUS di-commit (berisi template variabel tanpa nilai sensitif)
!.env.example

# Logs
logs/
*.log

# Runtime data
pids/
*.pid
*.pid.lock

# Test coverage
coverage/

# Temp files
tmp/
temp/

# OS generated files
.DS_Store
Thumbs.db

# Editor config
.vscode/
.idea/

# Build artifacts
*.tar.gz
*.tgz
