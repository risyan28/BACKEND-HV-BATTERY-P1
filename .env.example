# ================================
# Server Configuration
# ================================
PORT=4001
NODE_ENV=development

# ================================
# CORS Configuration
# ================================
# Comma-separated list of allowed origins
# Use "*" to allow all origins (NOT recommended for production)
# Example: http://localhost:3000,http://localhost:5173,http://10.10.10.100:3000
ALLOWED_ORIGINS=*

# ================================
# Prisma Database Configuration
# ================================
# Format: sqlserver://SERVER:PORT;database=DATABASE;user=USER;password=PASSWORD;trustServerCertificate=true;
DATABASE_URL=sqlserver://localhost:1433;database=HV_BATTERY;user=sa;password=YourPassword;trustServerCertificate=true;

# ================================
# MSSQL Direct Connection (for Change Tracking)
# ================================
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=HV_BATTERY
MSSQL_USER=sa
MSSQL_PASSWORD=YourPassword

# ================================
# Optional: Logging Configuration
# ================================
# Log level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# ================================
# Redis Cache Configuration (Phase 2)
# ================================
# Enable Redis caching (true/false)
REDIS_ENABLED=false
# Redis connection URL
REDIS_URL=redis://localhost:6379
# Redis connection pool size
REDIS_MAX_RETRIES=3

# ================================
# Sentry Error Tracking (Phase 2)
# ================================
# Enable Sentry error tracking (true/false)
SENTRY_ENABLED=false
# Sentry DSN from your Sentry project
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
# Environment name (development, staging, production)
SENTRY_ENVIRONMENT=development
# Sample rate for performance monitoring (0.0 to 1.0)
SENTRY_TRACES_SAMPLE_RATE=1.0

# ================================
# OpenTelemetry Configuration (Phase 2)
# ================================
# Enable OpenTelemetry tracing (true/false)
OTEL_ENABLED=false
# Service name for tracing
OTEL_SERVICE_NAME=hv-battery-backend
# Exporter endpoint (e.g., Jaeger, Zipkin)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ================================
# API Rate Limiting (Phase 2)
# ================================
# Rate limit window in minutes
RATE_LIMIT_WINDOW_MS=60000
# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100
